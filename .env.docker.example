# Docker Environment Variables
# Copy this file to .env.docker and fill in your values

# ============================================
# REQUIRED - Must change in production
# ============================================

# JWT Secret - Change this to a strong random string (min 32 chars)
# Generate: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# OpenAI API Key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Admin credentials for first login
ADMIN_EMAIL=admin@opencampus.vn

# Admin password hash - Generate with: node -e "console.log(require('bcrypt').hashSync('your-password', 10))"
# Default password: admin123 (CHANGE THIS IN PRODUCTION!)
ADMIN_PASSWORD_HASH=$2b$10$rZ8PYLhG5Y8nJ0wQ6qKQme7XL6K1mK5t1K7X5vK9h8L3Rz2Yz3Z4e

# ============================================
# OPTIONAL - Has defaults but can override
# ============================================

# AI Models (defaults are fine for most cases)
AI_STAGE_A_MODEL=gpt-4o-mini
AI_STAGE_B_MODEL=gpt-4o

# CORS Origin - Frontend URL (nginx proxy handles this in Docker)
CORS_ORIGIN=http://localhost

# Server Port (docker-compose already sets this)
# PORT=3000

# Node Environment (docker-compose already sets this)
# NODE_ENV=production

# Database URL (docker-compose already sets this)
# DATABASE_URL=postgresql://postgres:m1505@postgres:5432/rss_bot?schema=public
