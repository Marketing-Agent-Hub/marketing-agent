// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceLang {
  VI
  EN
  MIXED
}

enum ValidationStatus {
  OK
  FAILED
}

enum ItemStatus {
  NEW
  EXTRACTED
  FILTERED_OUT
  READY_FOR_AI
  AI_STAGE_A_DONE
  AI_STAGE_B_DONE
  USED
}

enum SourceType {
  RSS
  WEB_SCRAPER
  YOUTUBE
  SOCIAL_MEDIA
  CUSTOM_API
}

model Source {
  id                     Int               @id @default(autoincrement())
  name                   String
  rssUrl                 String?           @unique
  siteUrl                String?
  lang                   SourceLang        @default(MIXED)
  topicTags              String[]          @default([])
  trustScore             Int               @default(70)
  enabled                Boolean           @default(false)
  type                   SourceType        @default(RSS)
  config                 Json?
  fetchIntervalMinutes   Int               @default(60)
  denyKeywords           String[]          @default([])
  notes                  String?
  lastValidatedAt        DateTime?
  lastValidationStatus   ValidationStatus?
  lastFetchedAt          DateTime?
  lastFetchStatus        String?
  itemsCount             Int               @default(0)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  items                  Item[]

  @@index([enabled])
  @@index([trustScore])
  @@index([name]) // For search
  @@index([lang]) // For language filter
  @@index([createdAt]) // For sorting
  @@index([enabled, trustScore]) // For common query (enabled sources by trust)
  @@map("sources")
}

model Item {
  id                     Int               @id @default(autoincrement())
  sourceId               Int
  source                 Source            @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  
  guid                   String?
  title                  String
  link                   String
  snippet                String?
  contentHash            String            @unique
  publishedAt            DateTime?
  
  status                 ItemStatus        @default(NEW)
  filterReason           String?
  
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  article                Article?
  aiResults              AiResult[]

  @@unique([sourceId, link])
  @@index([status])
  @@index([sourceId])
  @@index([publishedAt])
  @@index([contentHash])
  @@map("items")
}

model Article {
  id                     Int               @id @default(autoincrement())
  itemId                 Int               @unique
  item                   Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  fullHtml               String?
  extractedContent       String
  truncatedContent       String?
  mainImageUrl           String?
  imageList              String[]          @default([])
  
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@map("articles")
}

model AiResult {
  id                     Int               @id @default(autoincrement())
  itemId                 Int
  item                   Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  stage                  String            // "A" or "B"
  
  // Stage A output
  isAllowed              Boolean?
  topicTags              String[]          @default([])
  importanceScore        Int?
  oneLineSummary         String?
  
  // Stage B output - Complete Facebook post
  fullArticle            String?
  
  // Metadata
  model                  String?
  promptTokens           Int?
  completionTokens       Int?
  totalTokens            Int?
  rawResponse            String?
  
  createdAt              DateTime          @default(now())

  @@index([itemId])
  @@index([stage])
  @@map("ai_results")
}

// ============ MONITORING MODELS ============

enum LogLevel {
  TRACE
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

enum MetricType {
  COUNTER
  GAUGE
  HISTOGRAM
  SUMMARY
}

enum HealthStatus {
  HEALTHY
  DEGRADED
  UNHEALTHY
}

model SystemLog {
  id                     Int               @id @default(autoincrement())
  level                  LogLevel
  message                String
  context                String?
  service                String?
  method                 String?
  path                   String?
  statusCode             Int?
  duration               Float?
  traceId                String?
  spanId                 String?
  userId                 Int?
  error                  String?
  stack                  String?
  metadata               Json?
  
  createdAt              DateTime          @default(now())

  @@index([level])
  @@index([service])
  @@index([traceId])
  @@index([createdAt])
  @@map("system_logs")
}

model SystemMetric {
  id                     Int               @id @default(autoincrement())
  name                   String
  type                   MetricType
  value                  Float
  unit                   String?
  labels                 Json?
  description            String?
  
  createdAt              DateTime          @default(now())

  @@index([name])
  @@index([type])
  @@index([createdAt])
  @@map("system_metrics")
}

model HealthCheck {
  id                     Int               @id @default(autoincrement())
  service                String
  status                 HealthStatus
  responseTime           Float?
  message                String?
  details                Json?
  
  checkedAt              DateTime          @default(now())

  @@index([service])
  @@index([status])
  @@index([checkedAt])
  @@map("health_checks")
}

model PerformanceTrace {
  id                     Int               @id @default(autoincrement())
  traceId                String            @unique
  spanId                 String?
  parentSpanId           String?
  name                   String
  kind                   String?
  startTime              DateTime
  endTime                DateTime?
  duration               Float?
  statusCode             Int?
  method                 String?
  path                   String?
  attributes             Json?
  events                 Json?
  
  createdAt              DateTime          @default(now())

  @@index([traceId])
  @@index([name])
  @@index([startTime])
  @@map("performance_traces")
}
