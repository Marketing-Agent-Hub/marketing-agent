// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceLang {
  VI
  EN
  MIXED
}

enum ValidationStatus {
  OK
  FAILED
}

enum ItemStatus {
  NEW
  EXTRACTED
  FILTERED_OUT
  READY_FOR_AI
  CURATOR_DONE
  WRITER_DONE
  USED
}

enum AgentType {
  SOCIAL_POST
  VIDEO
  LONGFORM
}

enum AgentFormat {
  FACEBOOK_POST
  TIKTOK_SCRIPT
  MEDIUM_ARTICLE
}

enum AgentDraftStatus {
  PENDING
  APPROVED
  PUBLISHED
  REJECTED
}

enum SourceType {
  RSS
  WEB_SCRAPER
  YOUTUBE
  SOCIAL_MEDIA
  CUSTOM_API
}

enum FilterMode {
  PASS_THROUGH
  AI_EMBEDDING
}

model Source {
  id                     Int               @id @default(autoincrement())
  name                   String
  rssUrl                 String?           @unique
  siteUrl                String?
  lang                   SourceLang        @default(MIXED)
  topicTags              String[]          @default([])
  trustScore             Int               @default(70)
  enabled                Boolean           @default(false)
  type                   SourceType        @default(RSS)
  config                 Json?
  fetchIntervalMinutes   Int               @default(60)
  denyKeywords           String[]          @default([])
  notes                  String?
  lastValidatedAt        DateTime?
  lastValidationStatus   ValidationStatus?
  lastFetchedAt          DateTime?
  lastFetchStatus        String?
  itemsCount             Int               @default(0)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  items                  Item[]
  brandSources           BrandSource[]

  @@index([enabled])
  @@index([trustScore])
  @@index([name]) // For search
  @@index([lang]) // For language filter
  @@index([createdAt]) // For sorting
  @@index([enabled, trustScore]) // For common query (enabled sources by trust)
  @@map("sources")
}

model Item {
  id                     Int               @id @default(autoincrement())
  brandId                Int
  brand                  Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  sourceId               Int
  source                 Source            @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  
  guid                   String?
  title                  String
  link                   String
  snippet                String?
  contentHash            String
  publishedAt            DateTime?
  
  status                 ItemStatus        @default(NEW)
  filterReason           String?
  
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  article                Article?
  aiResults              AiResult[]
  contentScript          ContentScript?

  @@unique([brandId, sourceId, link])
  @@index([status])
  @@index([sourceId])
  @@index([brandId])
  @@index([publishedAt])
  @@index([contentHash])
  @@map("items")
}

model Article {
  id                     Int               @id @default(autoincrement())
  itemId                 Int               @unique
  item                   Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  fullHtml               String?
  extractedContent       String
  truncatedContent       String?
  mainImageUrl           String?
  imageList              String[]          @default([])
  
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@map("articles")
}

model AiResult {
  id                     Int               @id @default(autoincrement())
  itemId                 Int
  item                   Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  stage                  String            // "A" or "B"
  
  // Stage A output
  isAllowed              Boolean?
  topicTags              String[]          @default([])
  importanceScore        Int?
  oneLineSummary         String?
  
  // Stage B output - Complete Facebook post
  fullArticle            String?
  
  // Metadata
  model                  String?
  promptTokens           Int?
  completionTokens       Int?
  totalTokens            Int?
  rawResponse            String?
  
  createdAt              DateTime          @default(now())

  @@index([itemId])
  @@index([stage])
  @@map("ai_results")
}

// ============ MONITORING MODELS ============

enum LogLevel {
  TRACE
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

enum MetricType {
  COUNTER
  GAUGE
  HISTOGRAM
  SUMMARY
}

enum HealthStatus {
  HEALTHY
  DEGRADED
  UNHEALTHY
}

model SystemLog {
  id                     Int               @id @default(autoincrement())
  level                  LogLevel
  message                String
  context                String?
  service                String?
  method                 String?
  path                   String?
  statusCode             Int?
  duration               Float?
  traceId                String?
  spanId                 String?
  userId                 Int?
  error                  String?
  stack                  String?
  metadata               Json?
  
  createdAt              DateTime          @default(now())

  @@index([level])
  @@index([service])
  @@index([traceId])
  @@index([createdAt])
  @@map("system_logs")
}

model SystemMetric {
  id                     Int               @id @default(autoincrement())
  name                   String
  type                   MetricType
  value                  Float
  unit                   String?
  labels                 Json?
  description            String?
  
  createdAt              DateTime          @default(now())

  @@index([name])
  @@index([type])
  @@index([createdAt])
  @@map("system_metrics")
}

model HealthCheck {
  id                     Int               @id @default(autoincrement())
  service                String
  status                 HealthStatus
  responseTime           Float?
  message                String?
  details                Json?
  
  checkedAt              DateTime          @default(now())

  @@index([service])
  @@index([status])
  @@index([checkedAt])
  @@map("health_checks")
}

model PerformanceTrace {
  id                     Int               @id @default(autoincrement())
  traceId                String            @unique
  spanId                 String?
  parentSpanId           String?
  name                   String
  kind                   String?
  startTime              DateTime
  endTime                DateTime?
  duration               Float?
  statusCode             Int?
  method                 String?
  path                   String?
  attributes             Json?
  events                 Json?
  
  createdAt              DateTime          @default(now())

  @@index([traceId])
  @@index([name])
  @@index([startTime])
  @@map("performance_traces")
}

// ============ V2 MARKETING AGENT MODELS ============

enum WorkspaceRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum BrandStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum StrategyStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  ARCHIVED
}

enum SlotStatus {
  PLANNED
  BRIEF_READY
  DRAFT_READY
  APPROVED
  SKIPPED
}

enum BriefStatus {
  DRAFT
  READY_FOR_REVIEW
  APPROVED
  REJECTED
}

enum DraftStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
  SCHEDULED
  PUBLISHED
  FAILED
  ARCHIVED
}

enum SocialPlatform {
  X
  FACEBOOK
  LINKEDIN
  TIKTOK
  INSTAGRAM
}

// --- Tenant & Auth ---

enum SystemRole {
  USER
  ADMIN
}

model User {
  id           Int               @id @default(autoincrement())
  email        String            @unique
  name         String?
  passwordHash String?
  googleId     String?           @unique
  systemRole   SystemRole        @default(USER)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  memberships  WorkspaceMember[]
  magicTokens  MagicLinkToken[]

  @@map("users")
}

model MagicLinkToken {
  id        Int       @id @default(autoincrement())
  tokenHash String    @unique
  userId    Int
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("magic_link_tokens")
}

model Workspace {
  id        Int               @id @default(autoincrement())
  name      String
  slug      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  members   WorkspaceMember[]
  brands    Brand[]

  @@index([slug])
  @@map("workspaces")
}

model WorkspaceMember {
  id          Int           @id @default(autoincrement())
  workspaceId Int
  userId      Int
  role        WorkspaceRole
  createdAt   DateTime      @default(now())

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

// --- Brand & Profile ---

model Brand {
  id              Int                      @id @default(autoincrement())
  workspaceId     Int
  name            String
  websiteUrl      String?
  industry        String?
  timezone        String?
  defaultLanguage String                   @default("en")
  status          BrandStatus              @default(ACTIVE)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  workspace       Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  profile         BrandProfile?
  knowledgeDocs   BrandKnowledgeDocument[]
  pillars         ContentPillar[]
  strategies      StrategyPlan[]
  socialAccounts  SocialAccount[]
  briefs          ContentBrief[]
  trendMatches    BrandTrendMatch[]
  brandSources    BrandSource[]
  filterProfile   FilterProfile?
  jobSchedules    JobSchedule[]
  items           Item[]
  contentScripts  ContentScript[]
  agentDrafts     AgentDraft[]
  agentConfig           ContentAgentConfig?
  mediaGenerationConfig MediaGenerationConfig?

  @@index([workspaceId, status])
  @@map("brands")
}

model BrandProfile {
  id              Int      @id @default(autoincrement())
  brandId         Int      @unique
  summary         String
  targetAudience  Json
  valueProps      Json
  toneGuidelines  Json
  businessGoals   Json
  messagingAngles Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  brand           Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@map("brand_profiles")
}

model BrandSource {
  id                   Int       @id @default(autoincrement())
  brandId              Int
  sourceId             Int
  fetchIntervalMinutes Int?
  enabled              Boolean   @default(true)
  lastFetchedAt        DateTime?
  lastFetchStatus      String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  source  Source @relation(fields: [sourceId], references: [id])

  @@unique([brandId, sourceId])
  @@index([enabled])
  @@index([brandId])
  @@map("brand_sources")
}

model FilterProfile {
  id                  Int        @id @default(autoincrement())
  brandId             Int        @unique
  mode                FilterMode @default(PASS_THROUGH)
  topicTags           String[]   @default([])
  description         String?
  similarityThreshold Float      @default(0.7)
  vectorProfile       Json?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@map("filter_profiles")
}

model BrandKnowledgeDocument {
  id        Int      @id @default(autoincrement())
  brandId   Int
  title     String
  sourceUrl String?
  content   String
  docType   String?
  createdAt DateTime @default(now())

  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@map("brand_knowledge_documents")
}

model OnboardingSession {
  id          Int       @id @default(autoincrement())
  brandId     Int
  transcript  Json      @default("[]")
  status      String    @default("IN_PROGRESS")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("onboarding_sessions")
}

// --- Strategy & Content ---

model ContentPillar {
  id          Int      @id @default(autoincrement())
  brandId     Int
  name        String
  description String?
  createdAt   DateTime @default(now())

  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@map("content_pillars")
}

model StrategyPlan {
  id            Int            @id @default(autoincrement())
  brandId       Int
  title         String
  objective     String
  status        StrategyStatus @default(DRAFT)
  startDate     DateTime
  endDate       DateTime
  cadenceConfig Json
  weeklyThemes  Json
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  brand         Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  slots         StrategySlot[]

  @@index([brandId, status, startDate])
  @@map("strategy_plans")
}

model StrategySlot {
  id             Int            @id @default(autoincrement())
  strategyPlanId Int
  brandId        Int
  channel        SocialPlatform
  pillarId       Int?
  scheduledFor   DateTime
  funnelStage    String?
  status         SlotStatus     @default(PLANNED)
  createdAt      DateTime       @default(now())

  strategyPlan   StrategyPlan   @relation(fields: [strategyPlanId], references: [id], onDelete: Cascade)

  @@index([brandId, scheduledFor, channel])
  @@map("strategy_slots")
}

model ContentBrief {
  id             Int            @id @default(autoincrement())
  brandId        Int
  strategySlotId Int?
  title          String
  objective      String?
  keyAngle       String?
  callToAction   String?
  assetDirection String?
  contentMode    String?
  sourceMetadata Json?
  status         BriefStatus    @default(DRAFT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  brand          Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  drafts         ContentDraft[]

  @@map("content_briefs")
}

model ContentDraft {
  id             Int               @id @default(autoincrement())
  contentBriefId Int
  platform       SocialPlatform
  body           String
  hook           String?
  cta            String?
  hashtags       String[]          @default([])
  sourceMetadata Json?
  status         DraftStatus       @default(DRAFT)
  version        Int               @default(1)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  contentBrief   ContentBrief      @relation(fields: [contentBriefId], references: [id], onDelete: Cascade)
  approvals      ContentApproval[]
  publishJobs    PublishJob[]

  @@index([status, updatedAt])
  @@map("content_drafts")
}

model ContentApproval {
  id             Int          @id @default(autoincrement())
  contentDraftId Int
  actorUserId    Int
  action         String
  comment        String?
  createdAt      DateTime     @default(now())

  contentDraft   ContentDraft @relation(fields: [contentDraftId], references: [id], onDelete: Cascade)

  @@map("content_approvals")
}

// --- Publishing & Analytics ---

model SocialAccount {
  id           Int            @id @default(autoincrement())
  brandId      Int
  platform     SocialPlatform
  accountName  String?
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  status       String         @default("CONNECTED")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  brand        Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@map("social_accounts")
}

model PublishJob {
  id             Int            @id @default(autoincrement())
  contentDraftId Int
  platform       SocialPlatform
  status         String         @default("SCHEDULED")
  scheduledFor   DateTime
  executedAt     DateTime?
  errorMessage   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  contentDraft   ContentDraft   @relation(fields: [contentDraftId], references: [id], onDelete: Cascade)
  publishedPost  PublishedPost?

  @@index([status, scheduledFor])
  @@map("publish_jobs")
}

model PublishedPost {
  id             Int                   @id @default(autoincrement())
  publishJobId   Int                   @unique
  externalPostId String?
  platform       SocialPlatform
  publishedAt    DateTime
  rawResponse    Json?
  createdAt      DateTime              @default(now())

  publishJob     PublishJob            @relation(fields: [publishJobId], references: [id], onDelete: Cascade)
  snapshots      PerformanceSnapshot[]

  @@index([externalPostId])
  @@map("published_posts")
}

model PerformanceSnapshot {
  id              Int           @id @default(autoincrement())
  publishedPostId Int
  likes           Int           @default(0)
  comments        Int           @default(0)
  shares          Int           @default(0)
  impressions     Int           @default(0)
  clicks          Int           @default(0)
  capturedAt      DateTime      @default(now())

  publishedPost   PublishedPost @relation(fields: [publishedPostId], references: [id], onDelete: Cascade)

  @@index([publishedPostId, capturedAt])
  @@map("performance_snapshots")
}

// --- Tracking & Audit ---

model Recommendation {
  id          Int      @id @default(autoincrement())
  brandId     Int
  type        String
  title       String
  description String
  data        Json?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("recommendations")
}

model AuditEvent {
  id          Int      @id @default(autoincrement())
  workspaceId Int?
  brandId     Int?
  actorUserId Int?
  action      String
  entityType  String?
  entityId    Int?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@map("audit_events")
}

model Setting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

model GenerationRun {
  id               Int      @id @default(autoincrement())
  workspaceId      Int?
  brandId          Int?
  workflow         String
  model            String?
  promptVersion    String?
  status           String
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  rawResponse      String?
  inputSnapshot    Json?
  outputSnapshot   Json?
  createdAt        DateTime @default(now())

  @@map("generation_runs")
}

model TrendSignal {
  id              Int      @id @default(autoincrement())
  itemId          Int?     @unique
  headline        String
  summary         String
  sourceName      String?
  canonicalUrl    String
  publishedAt     DateTime?
  topicTags       String[] @default([])
  importanceScore Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  brandMatches    BrandTrendMatch[]

  @@index([publishedAt])
  @@index([importanceScore])
  @@map("trend_signals")
}

model BrandTrendMatch {
  id             Int      @id @default(autoincrement())
  brandId        Int
  trendSignalId  Int
  relevanceScore Int
  reason         String?
  matchedAt      DateTime @default(now())

  brand          Brand       @relation(fields: [brandId], references: [id], onDelete: Cascade)
  trendSignal    TrendSignal @relation(fields: [trendSignalId], references: [id], onDelete: Cascade)

  @@unique([brandId, trendSignalId])
  @@index([brandId, matchedAt])
  @@index([trendSignalId])
  @@map("brand_trend_matches")
}

// ============ AI SOURCE DISCOVERY MODELS ============

enum PendingSourceStatus {
  PENDING
  APPROVED
  REJECTED
}

model PendingSource {
  id                    Int                  @id @default(autoincrement())
  feedUrl               String
  siteUrl               String?
  suggestedName         String?
  trustScore            Int
  topicTags             String[]             @default([])
  suggestedDenyKeywords String[]             @default([])
  qualityReason         String?
  feedType              String?
  status                PendingSourceStatus  @default(PENDING)
  rejectionReason       String?
  discoveredAt          DateTime             @default(now())
  sourceSearchQuery     String?
  promptTokens          Int?
  completionTokens      Int?

  @@unique([feedUrl, status])
  @@index([status])
  @@index([trustScore])
  @@index([discoveredAt])
  @@map("pending_sources")
}

model JobSchedule {
  id             Int      @id @default(autoincrement())
  brandId        Int
  jobType        String
  cronExpression String
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  brand          Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, jobType])
  @@index([enabled])
  @@index([jobType])
  @@map("job_schedules")
}

// ============ MULTI-AGENT CONTENT PIPELINE MODELS ============

model ContentScript {
  id           String   @id @default(uuid())
  brandId      Int
  brand        Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  itemId       Int      @unique
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  headline     String
  storyArc     String
  keyPoints    Json
  tone         String
  callToAction String?
  contentHash  String   @unique
  aiModel      String
  tokenUsage   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  drafts       AgentDraft[]
  @@index([brandId])
  @@map("content_scripts")
}

model AgentDraft {
  id           String           @id @default(uuid())
  brandId      Int
  brand        Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  scriptId     String
  script       ContentScript    @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  agent        AgentType
  format       AgentFormat
  content      String           @db.Text
  imageUrl     String?
  status       AgentDraftStatus @default(PENDING)
  reviewedAt   DateTime?
  reviewedBy   String?
  publishedAt  DateTime?
  publishedUrl String?
  aiModel      String
  tokenUsage   Int
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  @@unique([scriptId, agent])
  @@index([brandId, status])
  @@index([scriptId])
  @@map("agent_drafts")
}

model ContentAgentConfig {
  id                        String   @id @default(uuid())
  brandId                   Int      @unique
  brand                     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  enableSocialPostAgent     Boolean  @default(true)
  enableVideoAgent          Boolean  @default(false)
  enableLongformAgent       Boolean  @default(false)
  curatorModel              String?
  screenwriterModel         String?
  socialPostModel           String?
  videoModel                String?
  longformModel             String?
  socialPostMaxChars        Int      @default(500)
  socialPostIncludeHashtags Boolean  @default(true)
  socialPostIncludeEmoji    Boolean  @default(false)
  videoScriptMinSeconds     Int      @default(15)
  videoScriptMaxSeconds     Int      @default(60)
  videoScriptIncludeCTA     Boolean  @default(true)
  longformMinWords          Int      @default(1500)
  longformIncludeImages     Boolean  @default(false)
  enableImageForSocialPost  Boolean  @default(false)
  enableImageForLongform    Boolean  @default(false)
  imageModel                String   @default("openai/dall-e-3")
  stageAModel               String?  // null = use global setting for Stage A
  stageBModel               String?  // null = use global setting for Stage B
  embeddingModel            String?  // null = use global setting for embedding
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  @@map("content_agent_configs")
}

model MediaGenerationConfig {
  id          String   @id @default(uuid())
  brandId     Int      @unique
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  imageModel  String   @default("openai/dall-e-3")
  videoModel  String?
  audioModel  String?
  imageSize   String   @default("1024x1024")
  imageStyle  String   @default("natural")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("media_generation_configs")
}
