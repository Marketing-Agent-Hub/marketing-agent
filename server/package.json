{
    "name": "marketing-agent-server",
    "version": "1.0.0",
    "description": "AI-powered marketing agent backend with content intelligence and workflow automation",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:studio": "prisma studio",
        "lint": "eslint",
        "lint:fix": "eslint src --ext .ts --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "test": "vitest",
        "test:coverage": "vitest --coverage",
        "test:pipeline": "tsx test-pipeline.ts",
        "check:imports": "node scripts/check-imports.js"
    },
    "keywords": [
        "marketing",
        "ai",
        "social-media",
        "content-intelligence",
        "workflow-automation"
    ],
    "author": "Your Organization",
    "license": "MIT",
    "dependencies": {
        "@mozilla/readability": "^0.6.0",
        "@opentelemetry/api": "^1.9.0",
        "@opentelemetry/auto-instrumentations-node": "^0.70.1",
        "@opentelemetry/exporter-prometheus": "^0.212.0",
        "@opentelemetry/instrumentation-express": "^0.60.0",
        "@opentelemetry/instrumentation-http": "^0.212.0",
        "@opentelemetry/resources": "^2.5.1",
        "@opentelemetry/sdk-metrics": "^2.5.1",
        "@opentelemetry/sdk-node": "^0.212.0",
        "@opentelemetry/sdk-trace-node": "^2.5.1",
        "@opentelemetry/semantic-conventions": "^1.40.0",
        "@prisma/client": "5.22.0",
        "bcrypt": "^5.1.1",
        "cheerio": "^1.2.0",
        "cors": "^2.8.5",
        "dotenv": "^17.3.1",
        "express": "^4.21.2",
        "fast-xml-parser": "^4.5.0",
        "jsdom": "^28.1.0",
        "jsonwebtoken": "^9.0.2",
        "node-cron": "^4.2.1",
        "node-fetch": "^3.3.2",
        "openai": "^6.25.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsdom": "^28.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^20.17.10",
        "@types/node-cron": "^3.0.11",
        "@typescript-eslint/eslint-plugin": "^7.18.0",
        "@typescript-eslint/parser": "^7.18.0",
        "@vitest/coverage-v8": "^2.1.8",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.0",
        "fast-check": "^4.6.0",
        "prettier": "^3.4.2",
        "prisma": "5.22.0",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2",
        "vitest": "^2.1.8"
    }
}
