# Database
DATABASE_URL="postgresql://username:password@localhost:5432/news_aggregator?schema=public"

# JWT
JWT_SECRET="your-secret-key-change-in-production"

# Admin credentials
ADMIN_EMAIL="admin@example.com"
# Generate hash: bcrypt.hash("your-password", 10)
ADMIN_PASSWORD_HASH="$2b$10$..."

# CORS
CORS_ORIGIN="http://localhost:5173"

# Server
PORT=3001
NODE_ENV="development"

# HTTP Client
USER_AGENT="NewsAggregatorBot/1.0"

# OpenRouter AI
# One API key gives access to all models (Claude, Gemini, GPT, Qwen, etc.)
# Model names for each purpose (Stage A, Stage B, embedding, etc.) are configured
# via admin settings in the database — no need to set them here.
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# AI Source Discovery
TAVILY_API_KEY="tvly-..."

# Google OAuth
GOOGLE_CLIENT_ID="1008177923987-ni9f826qcbajld9lcf18f167rr4fi8g9.apps.googleusercontent.com"

# App URL (used for OAuth redirects and email links)
APP_URL="http://localhost:3001"

# SMTP / Email
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="noreply@example.com"

