# Database
DATABASE_URL="postgresql://username:password@localhost:5432/news_aggregator?schema=public"

# JWT
JWT_SECRET="your-secret-key-change-in-production"

# Admin credentials
ADMIN_EMAIL="admin@example.com"
# Generate hash: bcrypt.hash("your-password", 10)
ADMIN_PASSWORD_HASH="$2b$10$..."

# CORS
CORS_ORIGIN="http://localhost:5173"

# Server
PORT=3001
NODE_ENV="development"

# Application Branding
APP_NAME="News Aggregator"
APP_DESCRIPTION="AI-powered news aggregation system"
USER_AGENT="NewsAggregatorBot/1.0"

# Content Configuration
CONTENT_LANGUAGE="en"  # ISO 639-1: en, vi, es, fr, etc
TARGET_AUDIENCE="general audience"
FOCUS_TOPICS="technology,business,science,education"  # comma-separated

# OpenAI API
OPENAI_API_KEY="sk-..."
AI_STAGE_A_MODEL="gpt-4o-mini"
AI_STAGE_B_MODEL="gpt-4o"
