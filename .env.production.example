# File cấu hình cho Docker deployment
# Copy file này thành .env trên VPS và điền các giá trị

# ========================================
# GitHub Container Registry (GHCR)
# ========================================
# Registry sử dụng GitHub Container Registry (miễn phí)
DOCKER_REGISTRY=ghcr.io
# GitHub username của bạn (VD: john-doe)
GITHUB_USERNAME=your-github-username
# Tag của image (thường là latest)
IMAGE_TAG=latest

# ========================================
# Database Configuration
# ========================================
DATABASE_URL=postgresql://postgres:your-secure-password@postgres:5432/rss_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=rss_bot

# ========================================
# Application Configuration
# ========================================
NODE_ENV=production
PORT=3001

# ========================================
# JWT Configuration
# ========================================
JWT_SECRET=your-very-secure-jwt-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ========================================
# AI Configuration (OpenAI/Anthropic)
# ========================================
# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Hoặc Anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-3-haiku-20240307

AI_PROVIDER=openai

# ========================================
# Groq Configuration (Optional)
# ========================================
# GROQ_API_KEY=your-groq-api-key

# ========================================
# Monitoring & Logging
# ========================================
LOG_LEVEL=info
ENABLE_TELEMETRY=true

# ========================================
# RSS/Feed Configuration
# ========================================
INGEST_INTERVAL_MINUTES=60
FILTER_INTERVAL_MINUTES=5
EXTRACTION_INTERVAL_MINUTES=5
AI_STAGE_A_INTERVAL_MINUTES=10
AI_STAGE_B_INTERVAL_MINUTES=10

# ========================================
# Security
# ========================================
CORS_ORIGIN=http://your-domain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# Admin Credentials
# ========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your-hashed-password
